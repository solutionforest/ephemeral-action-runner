#!/usr/bin/env bash
set -u

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
    ps_script="$script_dir/run-epar.ps1"
    command -v cygpath >/dev/null 2>&1 && ps_script="$(cygpath -w "$ps_script")"
    exec powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$ps_script" "$@"
    ;;
esac

root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exe="$root/ephemeral-action-runner"
log_dir="$root/work/logs"
log_file="$log_dir/epar-last-run.log"
error_file="$log_dir/epar-last-error.log"

cd "$root" || exit 1
mkdir -p "$log_dir"

EPAR_HOST_TRUST_HELPER="$root/scripts/host-trust/host-trust-feed.sh"
# shellcheck disable=SC1091
. "$root/scripts/host-trust/wrapper-lib.sh"
epar_host_trust_prepare "$root" "${1:-start}" "$@" || exit $?
trap epar_host_trust_cleanup EXIT INT TERM
if [[ -n "${EPAR_HOST_TRUST_FEED_DIR}" ]]; then
  export EPAR_CONTROLLER_HOST_OS="$(epar_host_trust_host_os)"
  export EPAR_HOST_TRUST_FEED="${EPAR_HOST_TRUST_FEED_DIR}/current.json"
fi

{
  echo "EPAR run started: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  echo "Working directory: $root"
  printf "Command:"
  printf " %q" "$exe" "$@"
  echo
  echo
} >"$log_file"

if [[ ! -x "$exe" ]]; then
  echo "EPAR executable not found or not executable: $exe" | tee -a "$log_file"
  exit 1
fi

"$exe" "$@" 2>&1 | tee -a "$log_file"
code="${PIPESTATUS[0]}"

if [[ "$code" == "0" && "${1:-}" == "init" ]]; then
  epar_host_trust_post_init "$root" || code=$?
fi
epar_host_trust_cleanup
trap - EXIT INT TERM

if [[ "$code" -ne 0 ]]; then
  {
    echo
    echo "EPAR failed with exit code $code."
    if [[ -f "$error_file" ]]; then
      echo "Error report: $error_file"
    fi
    echo "Run log: $log_file"
  } | tee -a "$log_file"

  if [[ "${EPAR_NO_OPEN_LOG:-}" != "1" ]]; then
    open_file="$log_file"
    if [[ -f "$error_file" ]]; then
      open_file="$error_file"
    fi
    if [[ "$(uname -s)" == "Darwin" ]] && command -v open >/dev/null 2>&1; then
      open -t "$open_file" >/dev/null 2>&1 || true
    elif [[ -n "${DISPLAY:-}" ]] && command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$open_file" >/dev/null 2>&1 || true
    fi
  fi
fi

exit "$code"
